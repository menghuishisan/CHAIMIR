**/dist/
**/build/
**/.turbo/
**/.vite/
**/.cache/
**/*.tsbuildinfo

backend/bin/
backend/vendor/
backend/.gocache/
.gocache/
.testcache/

*.log
*.tar
images/vendor/**/*.tar.gz
images/vendor/**/*.zip
