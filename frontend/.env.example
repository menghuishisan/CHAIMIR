# 前端构建期环境变量示例。
# 后端统一 API 根地址，生产环境由部署层注入。
VITE_API_BASE_URL=/api/v1
# 可选：独立 WebSocket 根地址；默认由 API 地址推导。
VITE_WS_BASE_URL=
# 前端 API 请求超时时间。
VITE_API_TIMEOUT_MS=30000
# 该值由具体前端应用在装配层读取后,传入 sim-sdk 的 workerCommandTimeoutMs。
VITE_SIM_WORKER_COMMAND_TIMEOUT_MS=2000
# 登录成功后的四端跳转地址，生产由网关路径或部署域名注入。
VITE_STUDENT_APP_URL=/student/
VITE_TEACHER_APP_URL=/teacher/
VITE_SCHOOL_ADMIN_APP_URL=/school-admin/
VITE_PLATFORM_ADMIN_APP_URL=/platform-admin/
