{
  "name": "@chaimir/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Chaimir 区块链教学平台前端 Monorepo",
  "scripts": {
    "dev": "pnpm --filter @chaimir/app-web dev",
    "build": "turbo run build",
