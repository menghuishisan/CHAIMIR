# ============================================================================
# Chaimir 平台「唯一」环境变量键源(single source of truth)。
# ----------------------------------------------------------------------------
# 铁律(CLAUDE.md §6):配置全走环境变量,严禁硬编码端口/连接串/端点/阈值。
# 本文件是全平台环境变量键的唯一来源 —— 所有清单经此生成 ConfigMap,不在别处重复定义。
#   · 应用层(chaimir-system):生成 ConfigMap "chaimir-config",后端/worker/migrate envFrom 注入。
#   · 数据层(chaimir-data):生成 ConfigMap "chaimir-data-config",中间件 Pod 引用同源值。
# 密钥变量名也必须在此登记,但只能使用 "# secret-env: KEY" 注释形式,不得写成 KEY=。
# 这样变量名仍由本文件统一治理,但不会被 configMapGenerator 放入 ConfigMap。
# 每个变量都带注释说明用途。
# ============================================================================

# ---- 部署形态(由各 overlay 的 configMapGenerator merge 覆盖)----
# 部署模式:saas=公网多租户;school=私有化单校单租户。
DEPLOY_MODE=saas
# 平台管理员层开关:true 启用 /platform 入口与平台级任务;prod-school 置 false 关闭。
PLATFORM_LAYER_ENABLED=true
# 私有化单校固定租户 ID;DEPLOY_MODE=school 时由交付配置覆盖。
SCHOOL_TENANT_ID=

# ---- 服务监听 ----
# 后端 HTTP 监听地址(容器内全网卡)。
HTTP_ADDR=0.0.0.0
# 后端 HTTP 监听端口(与 Deployment containerPort / Service targetPort 一致)。
HTTP_PORT=8080
# M10 统一 WebSocket Hub 路径(引擎内 PTY/仿真流走各模块自有 WS,不走此路径)。
WS_PATH=/ws
# WebSocket Origin 白名单,逗号分隔;跨域访问必须显式列入。
WS_ALLOWED_ORIGINS=
# 日志级别:debug/info/warn/error(overlay 覆盖,本地 debug、生产 info)。
LOG_LEVEL=info
# 日志格式:json=结构化(含 trace_id/tenant_id,便于检索);text=人读。
LOG_FORMAT=json
# 运行环境标识:dev/staging/prod。
APP_ENV=prod
# 健康检查依赖探测超时时间(秒)。
HEALTH_CHECK_TIMEOUT_SECONDS=3
# HTTP 服务优雅关闭等待时间(秒)。
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10
# HTTP 请求头读取超时时间(秒),防止慢速头部连接占用服务资源。
HTTP_READ_HEADER_TIMEOUT_SECONDS=10
# WebSocket 读超时时间(秒),用于回收失活连接。
WS_READ_TIMEOUT_SECONDS=60
# WebSocket 写超时时间(秒),用于保护慢客户端写入。
WS_WRITE_TIMEOUT_SECONDS=10
# WebSocket ping 间隔(秒),用于触发对端 pong 续期。
WS_PING_INTERVAL_SECONDS=25
# WebSocket 单条入站消息最大字节数,防止异常客户端占用过多内存。
WS_READ_LIMIT_BYTES=1048576

# ---- PostgreSQL(RLS 多租户主库)----
# 数据库主机:集群内 chaimir-data 命名空间的 Service DNS(overlay 可覆盖为外部托管)。
PG_HOST=postgres.chaimir-data.svc.cluster.local
# 数据库端口。
PG_PORT=5432
# 数据库名(应用连接 + 中间件初始化共用此值,保证连接契约一致)。
PG_DATABASE=chaimir
# 数据库用户(应用连接角色,必须是非属主 chaimir_app,确保 RLS 生效)。
PG_USER=chaimir_app
# secret-env: PG_PASSWORD
# secret-env: PG_PRIV_USER
# secret-env: PG_PRIV_PASSWORD
# SSL 模式:disable(本地)/require(生产)。
PG_SSLMODE=disable
# 连接池上限(单后端副本)。
PG_MAX_CONNS=20
# 连接池最小保活连接数。
PG_MIN_CONNS=2
# 部署期 migrate 授权应用角色的数据库操作超时时间(秒)。
PG_GRANT_TIMEOUT_SECONDS=30

# ---- Redis(缓存/会话/未读计数/队列)----
# Redis 主机(集群内 Service DNS,overlay 可覆盖)。
REDIS_HOST=redis.chaimir-data.svc.cluster.local
# Redis 端口。
REDIS_PORT=6379
# secret-env: REDIS_PASSWORD
# Redis 逻辑库编号。
REDIS_DB=0
# Redis 启动连通性检查超时时间(秒)。
REDIS_PING_TIMEOUT_SECONDS=5

# ---- NATS(事件总线,模块反向通信)----
# NATS 连接 URL(集群内 Service DNS,overlay 可覆盖)。
NATS_URL=nats://nats.chaimir-data.svc.cluster.local:4222
# secret-env: NATS_TOKEN
# NATS 断线重连等待间隔(秒)。
NATS_RECONNECT_WAIT_SECONDS=2
# 事件消费失败后的最大重试次数,超出后进入死信主题。
NATS_CONSUMER_RETRY_MAX=3
# 事件消费重试等待间隔(毫秒),用于吸收短暂依赖抖动。
NATS_CONSUMER_RETRY_DELAY_MS=100
# 死信主题统一前缀,原主题会拼接在此前缀之后。
NATS_DEAD_LETTER_PREFIX=dead

# ---- MinIO(对象存储:代码/附件/报告/PDF/备份)----
# MinIO S3 API 端点(host:port,集群内 Service DNS)。
MINIO_ENDPOINT=minio.chaimir-data.svc.cluster.local:9000
# secret-env: MINIO_ACCESS_KEY
# secret-env: MINIO_SECRET_KEY
# 是否使用 TLS 连接 MinIO(本地 false,生产视端点而定)。
MINIO_USE_SSL=false
# 对象存储区域标识。
MINIO_REGION=cn-local
# 代码资产桶。
MINIO_BUCKET_CODE=chaimir-code
# 附件桶(讨论/作业附件)。
MINIO_BUCKET_ATTACHMENT=chaimir-attachment
# 报告/PDF 桶。
MINIO_BUCKET_REPORT=chaimir-report
# 备份桶(每日备份产物)。
MINIO_BUCKET_BACKUP=chaimir-backup
# MinIO 启动连通性检查超时时间(秒)。
MINIO_PING_TIMEOUT_SECONDS=5

# ---- 鉴权 Token 运行边界 ----
# Access Token 有效期(分钟)。
JWT_ACCESS_TTL_MIN=15
# Refresh Token 有效期(天)。
JWT_REFRESH_TTL_DAY=7
# JWT issuer 声明值。
JWT_ISSUER=chaimir
# secret-env: JWT_SIGNING_KEY
# secret-env: APP_ENCRYPTION_KEY
# secret-env: APP_HMAC_KEY
# 内部服务 HMAC 请求允许的时间偏移窗口(秒),超过窗口拒绝以防重放。
SERVICE_AUTH_MAX_SKEW_SECONDS=300

# Collector 只允许访问这些 URL 前缀,逗号分隔,由 M2 按同一沙箱内 Service DNS 注入。
CHAIMIR_COLLECTOR_ALLOWED_PREFIXES=

# ---- 上传边界 ----
# 账号/组织导入文件最大字节数。
UPLOAD_IMPORT_MAX_BYTES=10485760
# M5 题库附件单文件最大字节数。
UPLOAD_CONTENT_ATTACHMENT_MAX_BYTES=20971520
# M4 仿真包上传原始文件最大字节数。
UPLOAD_SIM_BUNDLE_MAX_BYTES=20971520
# M4 仿真包归档最大文件数。
UPLOAD_SIM_BUNDLE_MAX_FILES=200
# M4 仿真包归档展开后最大总字节数。
UPLOAD_SIM_BUNDLE_MAX_UNPACKED_BYTES=52428800
# M4 受控预览动态校验报告最大字节数。
UPLOAD_SIM_VALIDATION_REPORT_MAX_BYTES=1048576
# 是否强制执行上传病毒扫描;生产环境应保持 true。
UPLOAD_VIRUS_SCAN_REQUIRED=true
# 病毒扫描器网络类型;当前统一复用 clamd,通常为 tcp 或 unix。
UPLOAD_VIRUS_SCAN_NETWORK=tcp
# 病毒扫描器地址;启用强制扫描时必须提供,避免上传链路静默绕过。
UPLOAD_VIRUS_SCAN_ADDRESS=clamav:3310
# 病毒扫描单次超时时间(秒),避免扫描器异常拖垮上传链路。
UPLOAD_VIRUS_SCAN_TIMEOUT_SECONDS=10
# 允许进入病毒扫描器的最大文件字节数,超过后由业务侧拆分或拒绝。
UPLOAD_VIRUS_SCAN_MAX_BYTES=52428800
# 统一文件服务下载授权有效期(秒),模块签发短时下载令牌时默认使用。
STORAGE_DOWNLOAD_GRANT_TTL_SECONDS=300

# ---- 统一导入导出中心 ----
# 导入导出任务最大尝试次数,超过后进入 failed 终态。
TRANSFER_TASK_MAX_ATTEMPTS=3
# 导入导出任务重试等待间隔(毫秒),避免瞬时故障导致紧密空转。
TRANSFER_TASK_RETRY_DELAY_MS=1000
# 导入导出任务下载产物授权有效期(秒),用于下载中心短时令牌。
TRANSFER_TASK_DOWNLOAD_TTL_SECONDS=900

# ---- 竞赛外部源边界(M8)----
# 漏洞源同步响应体最大字节数,防止外部源异常占用内存。
CONTEST_VULN_SOURCE_MAX_RESPONSE_BYTES=10485760

# 漏洞源配置缺省超时时间,单位秒;单个源可在 1-60 秒范围内覆盖。
CONTEST_VULN_SOURCE_TIMEOUT_SECONDS=10

# 对抗赛后台撮合调度轮询间隔,单位秒。
CONTEST_MATCHMAKER_POLL_INTERVAL_SECONDS=5

# 对抗赛每轮最多处理的待执行对局数。
CONTEST_MATCHMAKER_BATCH_SIZE=20

# 解题赛同队同题提交最小间隔,单位秒。
CONTEST_SUBMIT_RATE_LIMIT_SECONDS=60

# 同队同题连续失败后的冷却窗口,单位秒。
CONTEST_FAILED_COOLDOWN_SECONDS=300

# 对抗赛新队伍天梯 ELO 初始分,撮合和结算统一使用。
CONTEST_BATTLE_ELO_INITIAL_SCORE=1000

# 对抗赛标准 ELO 公式 K 因子,用于控制单局积分波动幅度。
CONTEST_BATTLE_ELO_K_FACTOR=32

# ---- 通知事件消费(M10)----
# 通知事件消费失败后的最大尝试次数。
NOTIFY_EVENT_RETRY_MAX=3
# 通知事件重试等待间隔(毫秒)。
NOTIFY_EVENT_RETRY_DELAY_MS=100
# 站内信未读计数 Redis 键保留时长(小时)。
NOTIFY_UNREAD_TTL_HOURS=4320
# 同租户同通知类型发送限频窗口(秒),防止异常事件风暴写入大量站内信。
NOTIFY_SEND_RATE_WINDOW_SECONDS=60
# 同租户同通知类型在限频窗口内允许的最大发送次数。
NOTIFY_SEND_RATE_MAX=120
# 站内信保留天数,超过后由 M10 清理任务软删除。
NOTIFY_RETENTION_DAYS=180
# 站内信过期清理任务执行间隔(秒)。
NOTIFY_CLEANUP_INTERVAL_SECONDS=3600

# M11 等跨模块读取单课程成绩时允许返回的最大行数。
TEACHING_COURSE_GRADES_MAX_ROWS=10000
# M6 课程生命周期状态自动推进轮询间隔(秒)。
TEACHING_COURSE_STATUS_POLL_INTERVAL_SECONDS=60
# M6 自动判题 outbox 每轮派发的最大记录数。
TEACHING_JUDGE_OUTBOX_BATCH_SIZE=10
# M6 自动判题 outbox 后台轮询间隔(毫秒)。
TEACHING_JUDGE_OUTBOX_POLL_INTERVAL_MS=1000
# M6 成绩变更事件 outbox 每轮投递的最大记录数。
TEACHING_GRADE_EVENT_OUTBOX_BATCH_SIZE=100
# M6 成绩变更事件 outbox 后台轮询间隔(毫秒)。
TEACHING_GRADE_EVENT_OUTBOX_POLL_INTERVAL_MS=1000
# M6 成绩变更事件 outbox processing 状态超时重试间隔(毫秒)。
TEACHING_GRADE_EVENT_OUTBOX_STALE_INTERVAL_MS=60000
# M6 成绩导出读取 course_grade 时每批最大记录数。
TEACHING_GRADE_EXPORT_BATCH_SIZE=200

# ---- 实验实例生命周期(M7)----
# M7 实验实例回收调度器轮询间隔(秒)。
EXPERIMENT_RECYCLE_POLL_INTERVAL_SECONDS=60
# M7 实验实例回收调度器每轮处理上限。
EXPERIMENT_RECYCLE_BATCH_SIZE=100
# M7 进行中实例无人操作后的资源回收超时(秒),结果与代码引用保留。
EXPERIMENT_INSTANCE_IDLE_TIMEOUT_SECONDS=7200
# M7 暂停实例超过该时间后释放环境资源(秒)。
EXPERIMENT_PAUSED_TIMEOUT_SECONDS=86400
# M7 实验得分事件 outbox 每轮投递的最大记录数。
EXPERIMENT_SCORE_OUTBOX_BATCH_SIZE=100
# M7 实验得分事件 outbox 后台轮询间隔(毫秒)。
EXPERIMENT_SCORE_OUTBOX_POLL_INTERVAL_MS=1000
# M7 实验得分事件 outbox processing 状态超时重试间隔(毫秒)。
EXPERIMENT_SCORE_OUTBOX_STALE_INTERVAL_MS=60000

# ---- 短信验证码网关(M1)----
# dev/local 可覆盖为 log;生产必须配置 http 并接入校内/公网短信代理网关。
SMS_PROVIDER=http
# HTTP 短信代理网关地址;SMS_PROVIDER=http 时必填。
SMS_HTTP_ENDPOINT=
# secret-env: SMS_HTTP_TOKEN
# 登录验证码短信模板标识,由短信代理网关映射到具体厂商模板。
SMS_TEMPLATE_LOGIN=
# 找回密码验证码短信模板标识,由短信代理网关映射到具体厂商模板。
SMS_TEMPLATE_RESET=
# 换绑手机号验证码短信模板标识,由短信代理网关映射到具体厂商模板。
SMS_TEMPLATE_CHANGE_PHONE=
# 调用短信网关超时时间(秒)。
SMS_TIMEOUT_SECONDS=5

# ---- 身份服务运行边界(M1)----
# 激活码有效期(小时),用于待激活账号自设密码。
IDENTITY_ACTIVATION_CODE_TTL_HOURS=336
# CAS/LDAP 网络调用超时时间(秒)。
IDENTITY_SSO_NETWORK_TIMEOUT_SECONDS=10
# CAS serviceValidate 响应最大字节数,防止外部认证端点返回超大响应。
IDENTITY_SSO_CAS_RESPONSE_MAX_BYTES=1048576
# CAS service 回调 origin 白名单,逗号分隔;生产/私有化 overlay 必须覆盖为实际平台公网或校内网关域名。
IDENTITY_SSO_ALLOWED_SERVICE_ORIGINS=https://chaimir.example.edu
# 密码连续失败锁定阈值。
IDENTITY_PASSWORD_MAX_FAILED_COUNT=5
# 密码连续失败触发后的锁定时长(分钟)。
IDENTITY_PASSWORD_LOCK_MINUTES=15
# 同手机号同场景短信验证码重发间隔(秒)。
IDENTITY_SMS_RESEND_SECONDS=60
# 同手机号每日短信验证码最大发送次数。
IDENTITY_SMS_DAILY_LIMIT=10
# 短信验证码有效期(分钟)。
IDENTITY_SMS_CODE_TTL_MINUTES=5
# 短信验证码校验错误次数上限,达到后需重新获取验证码。
IDENTITY_SMS_VERIFY_MAX_ATTEMPTS=5
# 单次账号/组织导入允许的最大行数。
IDENTITY_IMPORT_MAX_ROWS=5000
# 导入预览服务端暂存有效期(小时)。
IDENTITY_IMPORT_PREVIEW_TTL_HOURS=24

# ---- 成绩中心运行边界(M11)----
# 成绩审核通过后允许学生提交申诉的天数。
GRADE_APPEAL_WINDOW_DAYS=30
# secret-env: GRADE_TRANSCRIPT_SIGNING_KEY
# 单份成绩单 PDF 允许写入对象存储的最大字节数。
GRADE_TRANSCRIPT_MAX_BYTES=1048576
# M11 成绩锁定事件 outbox 每轮发布的最大记录数。
GRADE_LOCK_OUTBOX_BATCH_SIZE=100
# M11 成绩锁定事件 outbox 后台轮询间隔(毫秒)。
GRADE_LOCK_OUTBOX_POLL_INTERVAL_MS=1000
# M11 处理中 outbox 超过该时间未完成时重新领取(毫秒)。
GRADE_LOCK_OUTBOX_STALE_INTERVAL_MS=60000

# ---- 部署期初始化(M1 seed)----
# 私有化首校短码;prod-school overlay 或交付配置覆盖为真实学校短码。
BOOTSTRAP_SCHOOL_TENANT_CODE=school-demo
# 私有化首校名称;prod-school overlay 或交付配置覆盖为真实学校名称。
BOOTSTRAP_SCHOOL_NAME=示例学校
# 私有化首校类型:1博士/2硕士/3本科/4专科。
BOOTSTRAP_SCHOOL_TYPE=3
# secret-env: BOOTSTRAP_ADMIN_PHONE
# secret-env: BOOTSTRAP_ADMIN_NAME
# secret-env: BOOTSTRAP_ADMIN_PASSWORD
# SaaS 首个平台管理员用户名;DEPLOY_MODE=saas 的 migrate-and-seed 使用。
BOOTSTRAP_PLATFORM_ADMIN_USERNAME=platform-admin
# SaaS 首个平台管理员显示名;生产可按运营组织命名。
BOOTSTRAP_PLATFORM_ADMIN_NAME=平台管理员
# secret-env: BOOTSTRAP_PLATFORM_ADMIN_PASSWORD

# ---- K8s 沙箱编排(后端 client-go 创建/销毁动态命名空间)----
# 留空=集群内 in-cluster 配置;否则指定 kubeconfig 路径。
KUBECONFIG_PATH=
# M2 学生沙箱命名空间前缀(sbx-<id>)。
SANDBOX_NS_PREFIX_STUDENT=sbx
# M3 判题沙箱命名空间前缀(judge-<id>)。
SANDBOX_NS_PREFIX_JUDGE=judge
# M8 对局沙箱命名空间前缀(battle-<id>)。
SANDBOX_NS_PREFIX_BATTLE=battle
# 镜像预拉取 DaemonSet 所在的受控命名空间。
SANDBOX_PREPULL_NAMESPACE=chaimir-prepull
# 沙箱工作负载节点选择器,key=value 逗号分隔;为空表示使用集群默认调度。
SANDBOX_NODE_SELECTOR=
# 沙箱工作负载节点容忍配置(JSON 数组);预拉取 DaemonSet 与沙箱 Pod 必须使用同一配置。
SANDBOX_NODE_TOLERATIONS_JSON=[]
# M2 沙箱回收事件 outbox 每轮投递的最大记录数。
SANDBOX_RECYCLE_OUTBOX_BATCH_SIZE=100
# M2 沙箱回收事件 outbox 后台轮询间隔(毫秒)。
SANDBOX_RECYCLE_OUTBOX_POLL_INTERVAL_MS=1000
# M2 沙箱回收事件 outbox processing 状态超时重试间隔(毫秒)。
SANDBOX_RECYCLE_OUTBOX_STALE_INTERVAL_MS=60000
# 沙箱/运行时镜像拉取的仓库地址前缀(overlay 覆盖为各环境 Harbor)。
IMAGE_REGISTRY=harbor.chaimir.local
# CI/Harbor 产出的镜像安全证明清单(JSON 数组),用于校验 digest、签名和扫描状态。
SANDBOX_IMAGE_ATTESTATIONS_JSON=[{"image_url":"harbor.chaimir.local/runtime/evm-hardhat@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa","digest":"sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa","cosign_verified":true,"trivy_status":"passed"}]
# 沙箱容器默认 CPU limit。
SANDBOX_DEFAULT_CPU=1
# 沙箱容器默认内存 limit。
SANDBOX_DEFAULT_MEMORY=1Gi
# 沙箱容器默认 CPU request。
SANDBOX_DEFAULT_REQUEST_CPU=250m
# 沙箱容器默认内存 request。
SANDBOX_DEFAULT_REQUEST_MEMORY=256Mi
# 单沙箱 Namespace CPU 总上限。
SANDBOX_MAX_CPU=4
# 单沙箱 Namespace 内存总上限。
SANDBOX_MAX_MEMORY=8Gi
# 单沙箱 Namespace Pod 数上限。
SANDBOX_MAX_PODS=16
# 沙箱工作区 PVC 容量。
SANDBOX_WORKSPACE_STORAGE=2Gi
# 沙箱 PVC 使用的 StorageClass 名称;启用快照时必须填写集群内真实可用的类。
SANDBOX_STORAGE_CLASS_NAME=
# 沙箱 CSI VolumeSnapshot 使用的 VolumeSnapshotClass 名称;启用快照时必须填写集群内真实可用的类。
SANDBOX_VOLUME_SNAPSHOT_CLASS_NAME=
# 镜像预拉取等待完成的超时时间(秒)。
SANDBOX_PREPULL_TIMEOUT_SECONDS=120
# 镜像预拉取 Pod 保持运行的时间(秒),用于确保镜像留在节点缓存。
SANDBOX_PREPULL_HOLD_SECONDS=3600
# 沙箱 Deployment 等待 Ready 的超时时间(秒)。
SANDBOX_READY_TIMEOUT_SECONDS=30
# 镜像预拉取 DaemonSet 状态轮询间隔(秒)。
SANDBOX_PREPULL_POLL_INTERVAL_SECONDS=2
# 沙箱 Deployment Ready 状态轮询间隔(秒)。
SANDBOX_READY_POLL_INTERVAL_SECONDS=1
# 预拉取 DaemonSet 容器 CPU request。
SANDBOX_PREPULL_REQUEST_CPU=10m
# 预拉取 DaemonSet 容器内存 request。
SANDBOX_PREPULL_REQUEST_MEMORY=32Mi
# 预拉取 DaemonSet 容器 CPU limit。
SANDBOX_PREPULL_LIMIT_CPU=100m
# 预拉取 DaemonSet 容器内存 limit。
SANDBOX_PREPULL_LIMIT_MEMORY=128Mi
# EVM/链能力 RPC 请求超时时间(秒)。
SANDBOX_CHAIN_RPC_TIMEOUT_SECONDS=10
# 内部受控 exec 命令默认超时时间(秒)。
SANDBOX_EXEC_TIMEOUT_SECONDS=120
# 初始代码归档允许读取的最大压缩字节数。
SANDBOX_INIT_ARCHIVE_MAX_BYTES=10485760
# 初始代码归档允许的最大文件数。
SANDBOX_INIT_ARCHIVE_MAX_FILES=200
# 初始代码归档允许的最大展开字节数。
SANDBOX_INIT_ARCHIVE_MAX_UNPACKED_BYTES=52428800
# 工作区文件写入后防抖保存延迟(毫秒)。
SANDBOX_FILE_SAVE_DEBOUNCE_MS=1500
# 未声明时 K8s 探针默认周期(秒)。
SANDBOX_PROBE_DEFAULT_PERIOD_SECONDS=2
# 未声明时 K8s 探针默认失败阈值。
SANDBOX_PROBE_DEFAULT_FAILURE_THRESHOLD=30
# 沙箱生命周期回收调度器轮询间隔(秒)。
SANDBOX_RECYCLE_POLL_INTERVAL_SECONDS=60
# 沙箱生命周期回收调度器每轮处理上限。
SANDBOX_RECYCLE_BATCH_SIZE=100
# 沙箱 ready/creating 后无人进入操作的回收超时(秒)。
SANDBOX_READY_IDLE_TIMEOUT_SECONDS=600
# 运行时接入即测结束后清理自检 Namespace 的超时时间(秒)。
SANDBOX_SELFTEST_RECYCLE_TIMEOUT_SECONDS=30
# 控制面所在 Namespace,用于允许沙箱回连控制面。
SANDBOX_CONTROL_NAMESPACE=chaimir-system
# 控制面 Pod 选择器标签 key。
SANDBOX_CONTROL_POD_LABEL_KEY=app.kubernetes.io/name
# 控制面 Pod 选择器标签 value。
SANDBOX_CONTROL_POD_LABEL_VALUE=chaimir-backend

# ---- 判题队列(M3)----
# 判题队列轮询间隔(毫秒)。
JUDGE_QUEUE_POLL_INTERVAL_MS=1000
# 判题 Worker 单次拉取任务数量。
JUDGE_WORKER_BATCH_SIZE=4
# 同账号同题提交限频窗口(秒)。
JUDGE_SUBMIT_RATE_LIMIT_SECONDS=10
# 判题任务默认最大重试次数。
JUDGE_DEFAULT_MAX_RETRIES=2
# 判题等待沙箱 Ready 的轮询间隔(毫秒)。
JUDGE_SANDBOX_READY_POLL_INTERVAL_MS=500
# 判题等待沙箱 Ready 时在任务超时外追加的环境准备宽限时间(秒)。
JUDGE_SANDBOX_READY_GRACE_SECONDS=30
# 判题结果 details JSON 序列化后的最大字节数,防止答案/套件源码或超大输出进入结果。
JUDGE_RESULT_DETAILS_MAX_BYTES=65536
# M3 向 judge 沙箱注入学生代码与判题套件并解包的超时时间(秒)。
JUDGE_INPUT_INJECT_TIMEOUT_SECONDS=60
# M3 判题输入归档允许的最大文件数。
JUDGE_INPUT_ARCHIVE_MAX_FILES=200
# M3 判题输入归档允许的最大展开字节数。
JUDGE_INPUT_ARCHIVE_MAX_UNPACKED_BYTES=52428800
# M3 查重相似度默认命中阈值,取值范围 0 到 1。
JUDGE_SIMILARITY_DEFAULT_THRESHOLD=0.8

# ---- M9 外接监控入口 ----
# M9 周期统计快照生成间隔(秒),用于写入 platform_statistics 加速趋势查询。
ADMIN_STATISTICS_SNAPSHOT_INTERVAL_SECONDS=3600
# JSON 数组,元素形如 {"key":"service-health","name":"服务健康","url":"https://grafana.example/d/...","scope":1}。
MONITORING_PANELS_JSON=[]

# ---- 雪花 ID ----
# 本实例节点编号(0-1023);生产多副本必须各不相同,K8s 建议由 StatefulSet Pod 序号注入。
SNOWFLAKE_NODE_ID=1
