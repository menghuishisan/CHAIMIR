# ============================================================================
# Chaimir 平台密钥环境变量模板(占位)。真实值绝不入仓库。
# ----------------------------------------------------------------------------
# 铁律(CLAUDE.md §6/§7):密钥走 K8s Secret/KMS,不入代码/镜像/仓库。
# 用法:
#   · 复制为各 overlay 目录下的 secret.env(被 .gitignore 忽略),填入真实/随机值。
#   · local-dev:make dev-up 自动由本模板生成随机 dev 值。
#   · prod-school:交付运维填入校内值。
#   · staging / prod-saas:不使用本文件 —— Secret 由 External Secrets/KMS 在集群创建。
# 经各 overlay 的 secretGenerator 生成:
#   · chaimir-secret(chaimir-system):应用/migrate 用。
#   · chaimir-data-secret(chaimir-data):中间件用(同源同值)。
# 每个变量都带注释说明用途。
#
# PowerShell 生成命令(兼容 Windows PowerShell 5.1;只输出随机值,不写文件;复制输出后填到对应变量):
#   $rng=[System.Security.Cryptography.RandomNumberGenerator]::Create(); $bytes=New-Object byte[] 32; $rng.GetBytes($bytes); -join ($bytes | ForEach-Object { $_.ToString('x2') })
# 16 字节十六进制值:
#   $rng=[System.Security.Cryptography.RandomNumberGenerator]::Create(); $bytes=New-Object byte[] 16; $rng.GetBytes($bytes); -join ($bytes | ForEach-Object { $_.ToString('x2') })
# 32 字节 Base64 值(APP_ENCRYPTION_KEY 专用,AES-256-GCM 要求解码后正好 32 字节):
#   $rng=[System.Security.Cryptography.RandomNumberGenerator]::Create(); $bytes=New-Object byte[] 32; $rng.GetBytes($bytes); [Convert]::ToBase64String($bytes)
# 符合本项目密码强度的随机初始密码(含字母和数字):
#   "Chaimir-" + (-join ((48..57 + 65..90 + 97..122) | Get-Random -Count 24 | ForEach-Object {[char]$_})) + "1"
# ============================================================================

# JWT 签名密钥(会话令牌签名;生产建议非对称私钥 PEM)。
# 生成:使用上方 32 字节十六进制值命令。
JWT_SIGNING_KEY=changeme-dev-jwt-signing-key
# 应用层敏感字段加密密钥(落库前加密)。
# 生成:使用上方 32 字节 Base64 值命令。
APP_ENCRYPTION_KEY=changeme-dev-encryption-key-base64-32b
# 应用层 HMAC 密钥(手机号、验证码、Refresh Token 等可查询哈希)。
# 生成:使用上方 32 字节十六进制值命令。
APP_HMAC_KEY=changeme-dev-hmac-key
# 成绩单 PDF/导出件签名密钥;用于验证成绩文件未被篡改。
# 生成:使用上方 32 字节十六进制值命令。
GRADE_TRANSCRIPT_SIGNING_KEY=changeme-dev-grade-transcript-signing-key
# PostgreSQL 密码(与 chaimir.env 的 PG_USER/PG_DATABASE 配套)。
# 生成:使用上方 32 字节十六进制值命令。
PG_PASSWORD=changeme-dev-pg-password
# PostgreSQL 特权用户名;仅中间件初始化、迁移和登录前受控跨租户查询使用。
PG_PRIV_USER=postgres
# PostgreSQL 特权用户密码;仅中间件初始化、迁移和受控特权路径使用。
# 生成:使用上方 32 字节十六进制值命令。
PG_PRIV_PASSWORD=changeme-dev-pg-owner-password
# Redis 访问密码(生产必设)。
# 生成:使用上方 32 字节十六进制值命令。
REDIS_PASSWORD=changeme-dev-redis-password
# MinIO 访问密钥(access key)。
# 生成:使用上方 16 字节十六进制值命令,或使用运维分配的可读 access key。
MINIO_ACCESS_KEY=changeme-dev-minio-access
# MinIO 秘密密钥(secret key)。
# 生成:使用上方 32 字节十六进制值命令。
MINIO_SECRET_KEY=changeme-dev-minio-secret
# NATS 连接 token(生产必设)。
# 生成:使用上方 32 字节十六进制值命令。
NATS_TOKEN=changeme-dev-nats-token
# HTTP 短信代理网关 Bearer Token(SMS_PROVIDER=http 时生产必设)。
# 生成:使用上方 32 字节十六进制值命令;若接入真实短信代理,以代理网关签发值为准。
SMS_HTTP_TOKEN=changeme-dev-sms-token
# 私有化首个学校管理员手机号;初始化时服务端加密与哈希入库。
BOOTSTRAP_ADMIN_PHONE=13800138000
# 私有化首个学校管理员姓名;与手机号一起作为首个高权限账号开通资料。
BOOTSTRAP_ADMIN_NAME=首个管理员
# 私有化首个学校管理员初始密码;只供 migrate-and-seed 首次创建账号,首登后强制修改。
# 生成:使用上方随机初始密码命令。
BOOTSTRAP_ADMIN_PASSWORD=changeme-dev-bootstrap-admin-password
# SaaS 首个平台管理员初始密码;只供 migrate-and-seed 首次创建账号,不得入 ConfigMap。
# 生成:使用上方随机初始密码命令。
BOOTSTRAP_PLATFORM_ADMIN_PASSWORD=changeme-dev-platform-admin-password
# DApp 钱包教学服务签名私钥;仅注入对应沙箱内 infra 容器。
# 生成:使用上方 32 字节十六进制值命令。
CHAIMIR_WALLET_SIGNER_PRIVATE_KEY=changeme-dev-wallet-signer-private-key
# DApp 钱包教学服务 HMAC 鉴权密钥;调用方必须按请求签名。
# 生成:使用上方 32 字节十六进制值命令。
CHAIMIR_WALLET_SESSION_SECRET=changeme-dev-wallet-session-secret
# 账户抽象 Paymaster 签名私钥;仅注入对应沙箱内 infra 容器。
# 生成:使用上方 32 字节十六进制值命令。
CHAIMIR_PAYMASTER_PRIVATE_KEY=changeme-dev-paymaster-private-key
# 账户抽象 Paymaster HMAC 鉴权密钥;调用方必须按请求签名。
# 生成:使用上方 32 字节十六进制值命令。
CHAIMIR_PAYMASTER_SERVICE_AUTH_SECRET=changeme-dev-paymaster-service-auth-secret
# 事件监听服务 HMAC 鉴权密钥;调用方必须按请求签名。
# 生成:使用上方 32 字节十六进制值命令。
CHAIMIR_EVENT_LISTENER_SERVICE_AUTH_SECRET=changeme-dev-event-listener-service-auth-secret
