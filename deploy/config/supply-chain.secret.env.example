# ============================================================================
# Chaimir 镜像供应链密钥模板。真实值绝不入仓库。
# ----------------------------------------------------------------------------
# 本文件只供 deploy/image-supply-chain.compose.yaml 和 deploy/Makefile 使用,
# 不参与 Chaimir 应用 Secret 生成,避免 Harbor/Cosign 高权限密钥注入后端 Pod。
# 用法:复制为 deploy/config/supply-chain.secret.env 后填写真实值。
# ============================================================================

# Harbor 初始管理员密码;仅用于容器化 Helm 安装 Harbor 时注入官方 chart。
# 生成:使用 deploy/config/secret.env.example 顶部的随机初始密码命令。
HARBOR_ADMIN_PASSWORD=changeme-harbor-admin-password
# Harbor robot 账号用户名;用于 CI/离线包推送镜像,生产建议由 Harbor 创建最小权限 robot。
HARBOR_ROBOT_USERNAME=robot-chaimir
# Harbor robot 账号密码/token;用于 docker login 和 CI 推送,以 Harbor 签发值为准。
HARBOR_ROBOT_PASSWORD=changeme-harbor-robot-password
# Cosign 私钥口令;私钥文件按 SUPPLY_CHAIN_COSIGN_KEY_HOST_DIR 配置挂载,不得入仓。
COSIGN_PRIVATE_KEY_PASSWORD=changeme-cosign-private-key-password
